# MongoDB Atlas
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=taskflow

# Authentication
APP_PASSWORD=change-me-please
SESSION_SECRET=generate-a-long-random-string-here-at-least-32-chars
SESSION_MAX_AGE_DAYS=30

# Application
APP_NAME=TaskFlow
DEBUG=false

# Telegram - התראות תזכורת למשימות
# צור בוט אצל @BotFather בטלגרם וקבל token.
# כדי לקבל chat_id: שלח לבוט הודעה כלשהי ואז פתח:
# https://api.telegram.org/bot<TOKEN>/getUpdates ושלוף chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# kill-switch כללי. גם אם token+chat_id מוגדרים - אפשר לכבות מכאן
TELEGRAM_ENABLED=true
# כל כמה דקות לבדוק תזכורות שהבשילו (reminder_date <= now)
TELEGRAM_REMINDER_CHECK_MINUTES=5

# לוח משימות שותף (mriox) - תוספת מבודדת
# ה-secret שמופיע בכתובת הציבורית: /m/<PARTNER_BOARD_SECRET>. ריק => המסך כבוי (404).
PARTNER_BOARD_SECRET=
# chat_id של השותף בטלגרם (אותו בוט קיים). ריק => אין תזכורות לשותף.
PARTNER_TELEGRAM_CHAT_ID=
# שעת התזכורת היומית לשותף (שעון PARTNER_TIMEZONE)
PARTNER_REMINDER_HOUR=20
PARTNER_REMINDER_MINUTE=0
PARTNER_TIMEZONE=Asia/Jerusalem

# Cloudflare R2 (לשלבים הבאים)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# גיבויים אוטומטיים של MongoDB (מימוש Python נטו, פלט ל-zip)
BACKUP_ENABLED=true
BACKUP_DIR=/var/data/backups
BACKUP_RETENTION_DAYS=7
BACKUP_HOUR=3
BACKUP_MINUTE=0

# סקירת משימות (Serendipity Review)
# כמה ימים משימה לא תוצג שוב בסקירה אחרי בחירת סטטוס. ברירת מחדל: 30
SERENDIPITY_COOLDOWN_DAYS=30
